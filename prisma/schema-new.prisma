generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum StaffTypeEnum {
  admin @map("admin")
  staff @map("staff")

  @@map("staff_type")
}

enum SellingStatusEnum {
  accepted    @map("accepted")
  notaccepted @map("notaccepted")

  @@map("selling_status")
}

enum PriceTypeEnum {
  cost      @map("cost")
  selling   @map("selling")
  wholesale @map("wholesale")

  @@map("price_type")
}

enum PageEnum {
  stat            @map("stat")
  product         @map("product")
  selling         @map("selling")
  arrival         @map("arrival")
  returning       @map("returning")
  client          @map("client")
  clientpayment   @map("clientpayment")
  clientreport    @map("clientreport")
  supplier        @map("supplier")
  supplierpayment @map("supplierpayment")
  stuff           @map("stuff")
  stuffpayment    @map("stuffpayment")

  @@map("page")
}

// ─────────────────────────────────────────────────────────────────────────────
// Currency
// ─────────────────────────────────────────────────────────────────────────────

model CurrencyModel {
  id           String  @map("id")            @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  name         String  @map("name")          @db.VarChar()      @unique
  symbol       String  @map("symbol")        @db.VarChar()
  isActive     Boolean @map("is_active")                        @default(true)
  exchangeRate Decimal @map("exchange_rate") @db.Decimal(10, 3) @default(0)

  staffs            StaffModel[]
  productPrices     ProductPriceModel[]
  sellingMVPrices   SellingProductMVPriceModel[]
  arrivalMVPrices   ArrivalProductMVPriceModel[]
  returningMVPrices ReturningProductMVPriceModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([name])
  @@index([symbol])
  @@map("currency")
}

// ─────────────────────────────────────────────────────────────────────────────
// Client
// ─────────────────────────────────────────────────────────────────────────────

model ClientModel {
  id       String  @map("id")       @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  fullname String  @map("fullname") @db.VarChar()
  phone    String  @map("phone")    @db.VarChar()      @unique

  sellings   SellingModel[]
  returnings ReturningModel[]
  payments   ClientPaymentModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([phone])
  @@index([createdAt])
  @@map("client")
}

// ─────────────────────────────────────────────────────────────────────────────
// Supplier
// ─────────────────────────────────────────────────────────────────────────────

model SupplierModel {
  id       String  @map("id")       @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  fullname String  @map("fullname") @db.VarChar()
  phone    String  @map("phone")    @db.VarChar()      @unique

  arrivals ArrivalModel[]
  payments SupplierPaymentModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([phone])
  @@index([createdAt])
  @@map("supplier")
}

// ─────────────────────────────────────────────────────────────────────────────
// Staff
// ─────────────────────────────────────────────────────────────────────────────

model StaffModel {
  id         String       @map("id")          @db.Uuid            @default(dbgenerated("GEN_RANDOM_UUID()"))
  fullname   String       @map("fullname")    @db.VarChar()
  phone      String       @map("phone")       @db.VarChar()       @unique
  password   String       @map("password")    @db.VarChar()
  token      String?      @map("token")       @db.VarChar()
  type       StaffTypeEnum                                        @default(staff)
  pages      PageEnum[]                                           @default([])
  currencyId String?      @map("currency_id") @db.Uuid

  currency CurrencyModel? @relation(fields: [currencyId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  sellings     SellingModel[]
  arrivals     ArrivalModel[]
  returnings   ReturningModel[]
  sellingMVs   SellingProductMVModel[]
  arrivalMVs   ArrivalProductMVModel[]
  returningMVs ReturningProductMVModel[]
  clientPayments   ClientPaymentModel[]
  supplierPayments SupplierPaymentModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([phone])
  @@index([type])
  @@index([createdAt])
  @@map("staff")
}

model ProductModel {
  id          String  @map("id")          @db.Uuid      @default(dbgenerated("GEN_RANDOM_UUID()"))
  name        String  @map("name")        @db.VarChar()
  description String? @map("description") @db.VarChar() @default("")
  count       Int     @map("count")       @db.Integer   @default(0)
  minAmount   Int     @map("min_amount")  @db.Integer   @default(0)

  prices       ProductPriceModel[]
  sellingMVs   SellingProductMVModel[]
  arrivalMVs   ArrivalProductMVModel[]
  returningMVs ReturningProductMVModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([name])
  @@index([createdAt])
  @@map("product")
}

model ProductPriceModel {
  id           String        @map("id")            @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  type         PriceTypeEnum @map("type")
  price        Decimal       @map("price")         @db.Decimal(10, 3) @default(0)
  totalPrice   Decimal       @map("total_price")   @db.Decimal(10, 3) @default(0)
  exchangeRate Decimal       @map("exchange_rate") @db.Decimal(10, 3) @default(0)
  productId    String        @map("product_id")    @db.Uuid
  currencyId   String        @map("currency_id")   @db.Uuid

  product  ProductModel  @relation(fields: [productId],  references: [id], onDelete: Cascade, onUpdate: NoAction)
  currency CurrencyModel @relation(fields: [currencyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([id])
  @@index([id])
  @@index([productId])
  @@index([currencyId])
  @@unique([type, productId])
  @@map("product_price")
}

// ─────────────────────────────────────────────────────────────────────────────
// Selling
// ─────────────────────────────────────────────────────────────────────────────

model SellingModel {
  id       String            @map("id")        @db.Uuid          @default(dbgenerated("GEN_RANDOM_UUID()"))
  publicId Int               @map("public_id") @db.Integer       @default(autoincrement())
  date     DateTime          @map("date")      @db.Timestamptz() @default(dbgenerated("NOW()"))
  status   SellingStatusEnum @map("status")                      @default(notaccepted)
  clientId String            @map("client_id") @db.Uuid
  staffId  String            @map("staff_id")  @db.Uuid

  client   ClientModel             @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff    StaffModel              @relation(fields: [staffId],  references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment  ClientPaymentModel?
  products SellingProductMVModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([date])
  @@index([status])
  @@index([clientId])
  @@index([createdAt])
  @@map("selling")
}

model SellingProductMVModel {
  id        String @map("id")         @db.Uuid    @default(dbgenerated("GEN_RANDOM_UUID()"))
  count     Int    @map("count")      @db.Integer @default(1)
  productId String @map("product_id") @db.Uuid
  sellingId String @map("selling_id") @db.Uuid
  staffId   String @map("staff_id")   @db.Uuid

  product ProductModel          @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  selling SellingModel          @relation(fields: [sellingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff   StaffModel            @relation(fields: [staffId],   references: [id], onDelete: Cascade, onUpdate: NoAction)
  prices  SellingProductMVPriceModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([sellingId])
  @@index([productId])
  @@index([createdAt])
  @@map("selling_product_mv")
}

model SellingProductMVPriceModel {
  id          String        @map("id")                    @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  type        PriceTypeEnum @map("type")
  price       Decimal       @map("price")                 @db.Decimal(10, 3) @default(0)
  totalPrice  Decimal       @map("total_price")           @db.Decimal(10, 3) @default(0)
  currencyId  String        @map("currency_id")           @db.Uuid
  sellingProductMVId String        @map("selling_product_mv_id") @db.Uuid

  currency  CurrencyModel         @relation(fields: [currencyId],  references: [id], onDelete: Cascade, onUpdate: NoAction)
  sellingProductMV SellingProductMVModel @relation(fields: [sellingProductMVId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([id])
  @@index([id])
  @@index([sellingProductMVId])
  @@index([currencyId])
  @@unique([type, sellingProductMVId])
  @@map("selling_product_mv_price")
}

// ─────────────────────────────────────────────────────────────────────────────
// Arrival
// ─────────────────────────────────────────────────────────────────────────────

model ArrivalModel {
  id         String   @map("id")          @db.Uuid          @default(dbgenerated("GEN_RANDOM_UUID()"))
  publicId   Int      @map("public_id")   @db.Integer       @default(autoincrement())
  date       DateTime @map("date")        @db.Timestamptz() @default(dbgenerated("NOW()"))
  supplierId String   @map("supplier_id") @db.Uuid
  staffId    String   @map("staff_id")    @db.Uuid

  supplier SupplierModel           @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff    StaffModel              @relation(fields: [staffId],    references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment  SupplierPaymentModel?
  products ArrivalProductMVModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([date])
  @@index([supplierId])
  @@index([createdAt])
  @@map("arrival")
}

model ArrivalProductMVModel {
  id        String @map("id")          @db.Uuid    @default(dbgenerated("GEN_RANDOM_UUID()"))
  count     Int    @map("count")       @db.Integer @default(1)
  productId String @map("product_id")  @db.Uuid
  arrivalId String @map("arrival_id")  @db.Uuid
  staffId   String @map("staff_id")    @db.Uuid

  product ProductModel          @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  arrival ArrivalModel          @relation(fields: [arrivalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff   StaffModel            @relation(fields: [staffId],   references: [id], onDelete: Cascade, onUpdate: NoAction)
  prices  ArrivalProductMVPriceModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([arrivalId])
  @@index([productId])
  @@index([createdAt])
  @@map("arrival_product_mv")
}

model ArrivalProductMVPriceModel {
  id          String        @map("id")                    @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  type        PriceTypeEnum @map("type")
  price       Decimal       @map("price")                 @db.Decimal(10, 3) @default(0)
  totalPrice  Decimal       @map("total_price")           @db.Decimal(10, 3) @default(0)
  currencyId  String        @map("currency_id")           @db.Uuid
  arrivalProductMVId String        @map("arrival_product_mv_id") @db.Uuid

  currency  CurrencyModel         @relation(fields: [currencyId],  references: [id], onDelete: Cascade, onUpdate: NoAction)
  arrivalProductMV ArrivalProductMVModel @relation(fields: [arrivalProductMVId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([id])
  @@index([id])
  @@index([arrivalProductMVId])
  @@index([currencyId])
  @@unique([type, arrivalProductMVId])
  @@map("arrival_product_mv_price")
}

// ─────────────────────────────────────────────────────────────────────────────
// Returning
// ─────────────────────────────────────────────────────────────────────────────

model ReturningModel {
  id       String            @map("id")        @db.Uuid          @default(dbgenerated("GEN_RANDOM_UUID()"))
  publicId Int               @map("public_id") @db.Integer       @default(autoincrement())
  date     DateTime          @map("date")      @db.Timestamptz() @default(dbgenerated("NOW()"))
  status   SellingStatusEnum @map("status")                      @default(notaccepted)
  clientId String            @map("client_id") @db.Uuid
  staffId  String            @map("staff_id")  @db.Uuid

  client   ClientModel              @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff    StaffModel               @relation(fields: [staffId],  references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment  ClientPaymentModel?
  products ReturningProductMVModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([date])
  @@index([status])
  @@index([clientId])
  @@index([createdAt])
  @@map("returning")
}

model ReturningProductMVModel {
  id          String @map("id")           @db.Uuid    @default(dbgenerated("GEN_RANDOM_UUID()"))
  count       Int    @map("count")        @db.Integer @default(1)
  productId   String @map("product_id")   @db.Uuid
  returningId String @map("returning_id") @db.Uuid
  staffId     String @map("staff_id")     @db.Uuid

  product   ProductModel           @relation(fields: [productId],   references: [id], onDelete: Cascade, onUpdate: NoAction)
  returning ReturningModel         @relation(fields: [returningId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff     StaffModel             @relation(fields: [staffId],     references: [id], onDelete: Cascade, onUpdate: NoAction)
  prices    ReturningProductMVPriceModel[]

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([returningId])
  @@index([productId])
  @@index([createdAt])
  @@map("returning_product_mv")
}

model ReturningProductMVPriceModel {
  id            String        @map("id")                      @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  type          PriceTypeEnum @map("type")
  price         Decimal       @map("price")                   @db.Decimal(10, 3) @default(0)
  totalPrice    Decimal       @map("total_price")             @db.Decimal(10, 3) @default(0)
  currencyId    String        @map("currency_id")             @db.Uuid
  returningProductMVId String        @map("returning_product_mv_id") @db.Uuid

  currency    CurrencyModel           @relation(fields: [currencyId],    references: [id], onDelete: Cascade, onUpdate: NoAction)
  returningProductMV ReturningProductMVModel @relation(fields: [returningProductMVId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([id])
  @@index([id])
  @@index([returningProductMVId])
  @@index([currencyId])
  @@unique([type, returningProductMVId])
  @@map("returning_product_mv_price")
}


// ─────────────────────────────────────────────────────────────────────────────
// Payments
// ─────────────────────────────────────────────────────────────────────────────

model ClientPaymentModel {
  id          String  @map("id")           @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  cash        Decimal @map("cash")         @db.Decimal(10, 3) @default(0)
  card        Decimal @map("card")         @db.Decimal(10, 3) @default(0)
  other       Decimal @map("other")        @db.Decimal(10, 3) @default(0)
  transfer    Decimal @map("transfer")     @db.Decimal(10, 3) @default(0)
  fromBalance Decimal @map("from_balance") @db.Decimal(10, 3) @default(0)
  total       Decimal @map("total")        @db.Decimal(10, 3) @default(0)
  description String? @map("description")  @db.VarChar()      @default("")
  clientId    String  @map("client_id")    @db.Uuid
  staffId     String  @map("staff_id")     @db.Uuid
  sellingId   String? @map("selling_id")   @db.Uuid           @unique
  returningId String? @map("returning_id") @db.Uuid           @unique

  client    ClientModel     @relation(fields: [clientId],    references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff     StaffModel      @relation(fields: [staffId],     references: [id], onDelete: Cascade, onUpdate: NoAction)
  selling   SellingModel?   @relation(fields: [sellingId],   references: [id], onDelete: Cascade, onUpdate: NoAction)
  returning ReturningModel? @relation(fields: [returningId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([clientId])
  @@index([sellingId])
  @@index([returningId])
  @@map("client_payment")
}

model SupplierPaymentModel {
  id          String  @map("id")          @db.Uuid           @default(dbgenerated("GEN_RANDOM_UUID()"))
  cash        Decimal @map("cash")        @db.Decimal(10, 3) @default(0)
  card        Decimal @map("card")        @db.Decimal(10, 3) @default(0)
  other       Decimal @map("other")       @db.Decimal(10, 3) @default(0)
  transfer    Decimal @map("transfer")    @db.Decimal(10, 3) @default(0)
  total       Decimal @map("total")       @db.Decimal(10, 3) @default(0)
  description String? @map("description") @db.VarChar()      @default("")
  supplierId  String  @map("supplier_id") @db.Uuid
  staffId     String  @map("staff_id")    @db.Uuid
  arrivalId   String? @map("arrival_id")  @db.Uuid           @unique

  supplier SupplierModel @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff    StaffModel    @relation(fields: [staffId],    references: [id], onDelete: Cascade, onUpdate: NoAction)
  arrival  ArrivalModel? @relation(fields: [arrivalId],  references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdAt DateTime  @map("created_at") @db.Timestamptz @default(dbgenerated("NOW()"))
  updatedAt DateTime  @map("updated_at") @db.Timestamptz @updatedAt
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@id([id])
  @@index([id])
  @@index([supplierId])
  @@index([arrivalId])
  @@map("supplier_payment")
}

// ─────────────────────────────────────────────────────────────────────────────
// Product
// ─────────────────────────────────────────────────────────────────────────────
